            "url": { "raw": "{{baseUrl_grievance}}/grievance/v1/complaints/{{complaintId}}/status", "host": ["{{baseUrl_grievance}}"], "path": ["grievance","v1","complaints","{{complaintId}}","status"] }
          }
        },
        {
          "name": "Complaints — Add Tag",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"label\": \"commission-increase\"\n}" },
            "url": { "raw": "{{baseUrl_grievance}}/grievance/v1/complaints/{{complaintId}}/tags", "host": ["{{baseUrl_grievance}}"], "path": ["grievance","v1","complaints","{{complaintId}}","tags"] }
          }
        },
        {
          "name": "Complaints — Add Comment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"body\": \"I experienced the same on Bykea last month.\"\n}" },
            "url": { "raw": "{{baseUrl_grievance}}/grievance/v1/complaints/{{complaintId}}/comments", "host": ["{{baseUrl_grievance}}"], "path": ["grievance","v1","complaints","{{complaintId}}","comments"] }
          }
        },
        {
          "name": "Complaints — Report",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"reason\": \"Contains personal information.\"\n}" },
            "url": { "raw": "{{baseUrl_grievance}}/grievance/v1/complaints/{{complaintId}}/report", "host": ["{{baseUrl_grievance}}"], "path": ["grievance","v1","complaints","{{complaintId}}","report"] }
          }
        },
        {
          "name": "Clusters — List",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl_grievance}}/grievance/v1/clusters?page=1&limit=20", "host": ["{{baseUrl_grievance}}"], "path": ["grievance","v1","clusters"], "query": [{"key":"page","value":"1"},{"key":"limit","value":"20"}] }
          }
        },
        {
          "name": "Clusters — Create",
          "event": [{ "listen": "test", "script": { "exec": ["const j=pm.response.json();if(j.data?.cluster?.id)pm.collectionVariables.set('clusterId',j.data.cluster.id);"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Careem Commission Spike Q1 2026\",\n  \"description\": \"Multiple workers reporting same commission increase.\"\n}" },
            "url": { "raw": "{{baseUrl_grievance}}/grievance/v1/clusters", "host": ["{{baseUrl_grievance}}"], "path": ["grievance","v1","clusters"] }
          }
        },
        {
          "name": "Clusters — Attach Complaints",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"complaintIds\": [\"{{complaintId}}\"]\n}" },
            "url": { "raw": "{{baseUrl_grievance}}/grievance/v1/clusters/{{clusterId}}/attach", "host": ["{{baseUrl_grievance}}"], "path": ["grievance","v1","clusters","{{clusterId}}","attach"] }
          }
        },
        {
          "name": "Clusters — Get Suggestions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl_grievance}}/grievance/v1/clusters/suggestions?seedId={{complaintId}}",
              "host": ["{{baseUrl_grievance}}"], "path": ["grievance","v1","clusters","suggestions"],
              "query": [{"key":"seedId","value":"{{complaintId}}"}]
            }
          }
        }
      ]
    }
  ]
