{
  "info": {
    "_postman_id": "fairgig-collection-v1",
    "name": "FairGig API",
    "description": "FairGig — Gig Worker Income & Rights Platform\n\nServices:\n- Auth Service        (port 3001)  /auth/v1/*\n- Earnings Service    (port 3002)  /earnings/v1/*\n- Certificate Service (port 3003)  /certificate/v1/*\n- Grievance Service   (port 3004)  /grievance/v1/*\n\nEnvironment variables to set:\n- {{baseUrl_auth}}, {{baseUrl_earnings}}, {{baseUrl_certificate}}, {{baseUrl_grievance}}\n- {{accessToken}} — auto-populated by Login/Register tests\n- {{shiftId}} — set manually after creating a shift",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl_auth",        "value": "http://localhost:3001" },
    { "key": "baseUrl_earnings",    "value": "http://localhost:3002" },
    { "key": "baseUrl_certificate", "value": "http://localhost:3003" },
    { "key": "baseUrl_grievance",   "value": "http://localhost:3004" },
    { "key": "accessToken",         "value": "" },
    { "key": "shiftId",             "value": "" },
    { "key": "importId",            "value": "" },
    { "key": "shareToken",          "value": "" },
    { "key": "complaintId",         "value": "" },
    { "key": "clusterId",           "value": "" }
  ],
  "item": [
    {
      "name": "Health Checks",
      "item": [
        {
          "name": "Auth — Health",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl_auth}}/health", "host": ["{{baseUrl_auth}}"], "path": ["health"] } }
        },
        {
          "name": "Earnings — Health",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl_earnings}}/health", "host": ["{{baseUrl_earnings}}"], "path": ["health"] } }
        },
        {
          "name": "Certificate — Health",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl_certificate}}/health", "host": ["{{baseUrl_certificate}}"], "path": ["health"] } }
        },
        {
          "name": "Grievance — Health",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl_grievance}}/health", "host": ["{{baseUrl_grievance}}"], "path": ["health"] } }
        }
      ]
    },
    {
      "name": "Auth /v1",
      "item": [
        {
          "name": "Register",
          "event": [{ "listen": "test", "script": { "exec": ["const j=pm.response.json();if(j.data?.accessToken)pm.collectionVariables.set('accessToken',j.data.accessToken);"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Ali Raza\",\n  \"email\": \"ali@example.com\",\n  \"phone\": \"+923001234567\",\n  \"password\": \"mypassword1\"\n}" },
            "url": { "raw": "{{baseUrl_auth}}/auth/v1/register", "host": ["{{baseUrl_auth}}"], "path": ["auth","v1","register"] }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": ["const j=pm.response.json();if(j.data?.accessToken)pm.collectionVariables.set('accessToken',j.data.accessToken);"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"ali@example.com\",\n  \"password\": \"mypassword1\"\n}" },
            "url": { "raw": "{{baseUrl_auth}}/auth/v1/login", "host": ["{{baseUrl_auth}}"], "path": ["auth","v1","login"] }
          }
        },
        {
          "name": "Refresh Token",
          "request": { "method": "POST", "header": [], "url": { "raw": "{{baseUrl_auth}}/auth/v1/refresh", "host": ["{{baseUrl_auth}}"], "path": ["auth","v1","refresh"] } }
        },
        {
          "name": "Logout",
          "request": { "method": "POST", "header": [], "url": { "raw": "{{baseUrl_auth}}/auth/v1/logout", "host": ["{{baseUrl_auth}}"], "path": ["auth","v1","logout"] } }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"ali@example.com\"\n}" },
            "url": { "raw": "{{baseUrl_auth}}/auth/v1/forgot-password", "host": ["{{baseUrl_auth}}"], "path": ["auth","v1","forgot-password"] }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"<token-from-email>\",\n  \"newPassword\": \"newpassword1\"\n}" },
            "url": { "raw": "{{baseUrl_auth}}/auth/v1/reset-password", "host": ["{{baseUrl_auth}}"], "path": ["auth","v1","reset-password"] }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl_auth}}/auth/v1/me", "host": ["{{baseUrl_auth}}"], "path": ["auth","v1","me"] }
          }
        },
        {
          "name": "Update Me",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Ali Updated\",\n  \"language\": \"ur\"\n}" },
            "url": { "raw": "{{baseUrl_auth}}/auth/v1/me", "host": ["{{baseUrl_auth}}"], "path": ["auth","v1","me"] }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"oldPassword\": \"mypassword1\",\n  \"newPassword\": \"newpassword1\"\n}" },
            "url": { "raw": "{{baseUrl_auth}}/auth/v1/change-password", "host": ["{{baseUrl_auth}}"], "path": ["auth","v1","change-password"] }
          }
        },
        {
          "name": "Create Role Request",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"requestedRole\": \"employer\",\n  \"reason\": \"I want to post jobs.\"\n}" },
            "url": { "raw": "{{baseUrl_auth}}/auth/v1/role-requests", "host": ["{{baseUrl_auth}}"], "path": ["auth","v1","role-requests"] }
          }
        },
        {
          "name": "List Role Requests (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl_auth}}/auth/v1/role-requests?page=1&limit=20", "host": ["{{baseUrl_auth}}"], "path": ["auth","v1","role-requests"], "query": [{"key":"page","value":"1"},{"key":"limit","value":"20"}] }
          }
        },
        {
          "name": "Approve Role Request (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl_auth}}/auth/v1/role-requests/<id>/approve", "host": ["{{baseUrl_auth}}"], "path": ["auth","v1","role-requests","<id>","approve"] }
          }
        },
        {
          "name": "Reject Role Request (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": { "raw": "{{baseUrl_auth}}/auth/v1/role-requests/<id>/reject", "host": ["{{baseUrl_auth}}"], "path": ["auth","v1","role-requests","<id>","reject"] }
          }
        },
        {
          "name": "Update User Status (Admin)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"frozen\"\n}" },
            "url": { "raw": "{{baseUrl_auth}}/auth/v1/admin/users/<user-id>/status", "host": ["{{baseUrl_auth}}"], "path": ["auth","v1","admin","users","<user-id>","status"] }
          }
        }
      ]
    },
    {
      "name": "Earnings /v1",
      "item": [
        {
          "name": "Reference — List Platforms",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl_earnings}}/earnings/v1/platforms", "host": ["{{baseUrl_earnings}}"], "path": ["earnings","v1","platforms"] }
          }
        },
        {
          "name": "Reference — List City Zones",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl_earnings}}/earnings/v1/city-zones", "host": ["{{baseUrl_earnings}}"], "path": ["earnings","v1","city-zones"] }
          }
        },
        {
          "name": "Shifts — Create",
          "event": [{ "listen": "test", "script": { "exec": ["const j=pm.response.json();if(j.data?.shift?.id)pm.collectionVariables.set('shiftId',j.data.shift.id);"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"platformId\": \"<platform-cuid>\",\n  \"shiftDate\": \"2026-04-18\",\n  \"hoursWorked\": 6.5,\n  \"grossPay\": 1200,\n  \"deductions\": 100,\n  \"netPay\": 1100,\n  \"notes\": \"Night shift\"\n}" },
            "url": { "raw": "{{baseUrl_earnings}}/earnings/v1/shifts", "host": ["{{baseUrl_earnings}}"], "path": ["earnings","v1","shifts"] }
          }
        },
        {
          "name": "Shifts — List",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl_earnings}}/earnings/v1/shifts?page=1&limit=20",
              "host": ["{{baseUrl_earnings}}"], "path": ["earnings","v1","shifts"],
              "query": [{"key":"page","value":"1"},{"key":"limit","value":"20"}]
            }
          }
        },
        {
          "name": "Shifts — Get by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl_earnings}}/earnings/v1/shifts/{{shiftId}}", "host": ["{{baseUrl_earnings}}"], "path": ["earnings","v1","shifts","{{shiftId}}"] }
          }
        },
        {
          "name": "Shifts — Update",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"notes\": \"Updated note\",\n  \"hoursWorked\": 7\n}" },
            "url": { "raw": "{{baseUrl_earnings}}/earnings/v1/shifts/{{shiftId}}", "host": ["{{baseUrl_earnings}}"], "path": ["earnings","v1","shifts","{{shiftId}}"] }
          }
        },
        {
          "name": "Shifts — Delete",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl_earnings}}/earnings/v1/shifts/{{shiftId}}", "host": ["{{baseUrl_earnings}}"], "path": ["earnings","v1","shifts","{{shiftId}}"] }
          }
        },
        {
          "name": "Screenshots — Presign Upload URL",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"mimeType\": \"image/jpeg\",\n  \"sizeBytes\": 512000\n}" },
            "url": { "raw": "{{baseUrl_earnings}}/earnings/v1/shifts/{{shiftId}}/screenshots/presign", "host": ["{{baseUrl_earnings}}"], "path": ["earnings","v1","shifts","{{shiftId}}","screenshots","presign"] }
          }
        },
        {
          "name": "Screenshots — Confirm Upload",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"storageKey\": \"screenshots/<workerId>/<shiftId>/<uuid>.jpg\",\n  \"sizeBytes\": 512000,\n  \"mimeType\": \"image/jpeg\"\n}" },
            "url": { "raw": "{{baseUrl_earnings}}/earnings/v1/shifts/{{shiftId}}/screenshots", "host": ["{{baseUrl_earnings}}"], "path": ["earnings","v1","shifts","{{shiftId}}","screenshots"] }
          }
        },
        {
          "name": "Screenshots — Get Signed Download URL",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl_earnings}}/earnings/v1/shifts/{{shiftId}}/screenshots/url", "host": ["{{baseUrl_earnings}}"], "path": ["earnings","v1","shifts","{{shiftId}}","screenshots","url"] }
          }
        },
        {
          "name": "Verification — Submit Decision",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"decision\": \"confirmed\",\n  \"notes\": \"Screenshots match the reported earnings.\"\n}" },
            "url": { "raw": "{{baseUrl_earnings}}/earnings/v1/shifts/{{shiftId}}/verify", "host": ["{{baseUrl_earnings}}"], "path": ["earnings","v1","shifts","{{shiftId}}","verify"] }
          }
        },
        {
          "name": "Verification — Queue (Verifier/Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl_earnings}}/earnings/v1/verification/queue?page=1&limit=20",
              "host": ["{{baseUrl_earnings}}"], "path": ["earnings","v1","verification","queue"],
              "query": [{"key":"page","value":"1"},{"key":"limit","value":"20"}]
            }
          }
        },
        {
          "name": "CSV Import — Download Template",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl_earnings}}/earnings/v1/imports/template", "host": ["{{baseUrl_earnings}}"], "path": ["earnings","v1","imports","template"] }
          }
        },
        {
          "name": "CSV Import — Upload CSV",
          "event": [{ "listen": "test", "script": { "exec": ["const j=pm.response.json();if(j.data?.importId)pm.collectionVariables.set('importId',j.data.importId);"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": { "mode": "formdata", "formdata": [{ "key": "file", "type": "file", "src": "/path/to/shifts.csv" }] },
            "url": { "raw": "{{baseUrl_earnings}}/earnings/v1/imports/csv", "host": ["{{baseUrl_earnings}}"], "path": ["earnings","v1","imports","csv"] }
          }
        },
        {
          "name": "CSV Import — Poll Status",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl_earnings}}/earnings/v1/imports/{{importId}}", "host": ["{{baseUrl_earnings}}"], "path": ["earnings","v1","imports","{{importId}}"] }
          }
        }
      ]
    },
    {
      "name": "Certificate /v1",
      "item": [
        {
          "name": "Certificate — Build (Preview)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl_certificate}}/certificate/v1/build?from=2026-01-01&to=2026-03-31",
              "host": ["{{baseUrl_certificate}}"], "path": ["certificate","v1","build"],
              "query": [{"key":"from","value":"2026-01-01"},{"key":"to","value":"2026-03-31"}]
            }
          }
        },
        {
          "name": "Certificate — Share (Create Link)",
          "event": [{ "listen": "test", "script": { "exec": ["const j=pm.response.json();if(j.data?.shareToken)pm.collectionVariables.set('shareToken',j.data.shareToken);"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"from\": \"2026-01-01\",\n  \"to\": \"2026-03-31\",\n  \"ttlDays\": 14\n}" },
            "url": { "raw": "{{baseUrl_certificate}}/certificate/v1/share", "host": ["{{baseUrl_certificate}}"], "path": ["certificate","v1","share"] }
          }
        },
        {
          "name": "Certificate — Public View (JSON)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{baseUrl_certificate}}/certificate/v1/public/{{shareToken}}", "host": ["{{baseUrl_certificate}}"], "path": ["certificate","v1","public","{{shareToken}}"] }
          }
        },
        {
          "name": "Certificate — Public View (Print HTML)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "text/html" }],
            "url": { "raw": "{{baseUrl_certificate}}/certificate/v1/public/{{shareToken}}", "host": ["{{baseUrl_certificate}}"], "path": ["certificate","v1","public","{{shareToken}}"] }
          }
        },
        {
          "name": "Certificate — Revoke",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl_certificate}}/certificate/v1/{{shareToken}}/revoke", "host": ["{{baseUrl_certificate}}"], "path": ["certificate","v1","{{shareToken}}","revoke"] }
          }
        }
      ]
    },
    {
      "name": "Grievance /v1",
      "item": [
        {
          "name": "Board — Public Bulletin",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl_grievance}}/grievance/v1/board?page=1&limit=20",
              "host": ["{{baseUrl_grievance}}"], "path": ["grievance","v1","board"],
              "query": [{"key":"page","value":"1"},{"key":"limit","value":"20"}]
            }
          }
        },
        {
          "name": "Complaints — Create",
          "event": [{ "listen": "test", "script": { "exec": ["const j=pm.response.json();if(j.data?.complaint?.id)pm.collectionVariables.set('complaintId',j.data.complaint.id);"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
