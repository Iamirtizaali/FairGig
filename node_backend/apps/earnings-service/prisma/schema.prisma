// Earnings Service — Prisma Schema
// Schemas owned: earnings, audit

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  output          = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["earnings", "audit"]
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ShiftSource {
  manual
  csv
  ocr

  @@schema("earnings")
}

enum VerificationStatus {
  pending
  confirmed
  discrepancy
  unverifiable

  @@schema("earnings")
}

enum ImportStatus {
  queued
  processing
  done
  failed

  @@schema("earnings")
}

enum ShiftVerificationStatus {
  self_attested
  pending_review
  verified
  discrepancy_flagged
  unverifiable

  @@schema("earnings")
}

// ─── Platform catalogue ───────────────────────────────────────────────────────

model Platform {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  logoUrl     String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  shifts      Shift[]

  @@map("platforms")
  @@schema("earnings")
}

// ─── City / district zones ────────────────────────────────────────────────────

model CityZone {
  id        String   @id @default(cuid())
  city      String
  zone      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  shifts    Shift[]

  @@unique([city, zone])
  @@map("city_zones")
  @@schema("earnings")
}

// ─── Core shift record ────────────────────────────────────────────────────────
// Financial integrity CHECK constraints (gross_pay >= 0, hours_worked > 0, net_pay >= 0)
// are applied as raw SQL in the migration (see below).

model Shift {
  id             String       @id @default(cuid())
  workerId       String
  platformId     String
  cityZoneId     String?
  shiftDate      DateTime     @db.Date
  hoursWorked    Decimal      @db.Decimal(6, 2)
  grossPay       Decimal      @db.Decimal(12, 2)
  deductions     Decimal      @default(0) @db.Decimal(12, 2)
  netPay         Decimal      @db.Decimal(12, 2)
  currency       String       @default("PKR") @db.Char(3)
  source             ShiftSource             @default(manual)
  verificationStatus ShiftVerificationStatus  @default(self_attested)
  notes              String?
  deletedAt          DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  platform       Platform     @relation(fields: [platformId], references: [id])
  cityZone       CityZone?    @relation(fields: [cityZoneId], references: [id])
  screenshots    Screenshot[]
  verifications  Verification[]
  anomalyFlags   AnomalyFlag[]

  @@index([workerId])
  @@index([shiftDate])
  @@index([platformId])
  @@map("shifts")
  @@schema("earnings")
}

// ─── Screenshots ──────────────────────────────────────────────────────────────

model Screenshot {
  id          String   @id @default(cuid())
  shiftId     String
  storageKey  String   @unique
  mimeType    String   @default("image/jpeg")
  sizeBytes   Int
  uploadedAt  DateTime @default(now())
  deletedAt   DateTime?

  shift       Shift    @relation(fields: [shiftId], references: [id])

  @@index([shiftId])
  @@map("screenshots")
  @@schema("earnings")
}

// ─── Verifications ────────────────────────────────────────────────────────────

model Verification {
  id           String             @id @default(cuid())
  shiftId      String
  verifierId   String
  screenshotId String?
  status       VerificationStatus @default(pending)
  notes        String?
  decidedAt    DateTime?
  createdAt    DateTime           @default(now())

  shift        Shift              @relation(fields: [shiftId], references: [id])

  @@index([shiftId])
  @@map("verifications")
  @@schema("earnings")
}

// ─── Anomaly flags ────────────────────────────────────────────────────────────

model AnomalyFlag {
  id         String   @id @default(cuid())
  shiftId    String
  flaggedBy  String   @default("anomaly-service")
  reason     String
  score      Decimal? @db.Decimal(5, 4)
  resolvedAt DateTime?
  createdAt  DateTime @default(now())

  shift      Shift    @relation(fields: [shiftId], references: [id])

  @@index([shiftId])
  @@map("anomaly_flags")
  @@schema("earnings")
}

// ─── CSV imports ──────────────────────────────────────────────────────────────

model CsvImport {
  id          String       @id @default(cuid())
  workerId    String
  storageKey  String
  status      ImportStatus @default(queued)
  rowsTotal   Int          @default(0)
  rowsOk      Int          @default(0)
  rowsFailed  Int          @default(0)
  errorLog    Json?
  errorCsvKey String?
  jobId       String?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime     @default(now())

  @@index([workerId])
  @@map("csv_imports")
  @@schema("earnings")
}

// ─── In-app notifications ──────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  link      String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("notifications")
  @@schema("earnings")
}

// ─── Certificates (metadata — generated by certificate-service) ───────────────

model Certificate {
  id          String    @id @default(cuid())
  workerId    String
  periodStart DateTime  @db.Date
  periodEnd   DateTime  @db.Date
  shareToken  String    @unique @default(uuid())
  expiresAt   DateTime
  revokedAt   DateTime?
  issuedAt    DateTime  @default(now())

  @@index([workerId])
  @@index([shareToken])
  @@map("certificates")
  @@schema("earnings")
}

// ─── Audit events (read-only replica of auth.audit_events for this service) ───

model AuditEvent {
  id        String   @id @default(cuid())
  actorId   String?
  actorRole String?
  action    String
  entity    String
  entityId  String
  diff      Json     @default("{}")
  ip        String?
  ua        String?
  createdAt DateTime @default(now())

  @@map("events")
  @@schema("audit")
}
