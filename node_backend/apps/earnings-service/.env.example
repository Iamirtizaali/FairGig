# ── Earnings Service Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in real values before running.
# NEVER commit the .env file to version control.

# Server
NODE_ENV=development
PORT=3002

# Database (same Postgres instance as other services, earnings schema)
DATABASE_URL=postgresql://postgres:password@localhost:5432/fairgig

# JWT — must match the value in auth-service (this service only verifies)
JWT_SECRET=change_me_to_a_64_char_random_hex_string

# CORS
FRONTEND_ORIGINS=http://localhost:5173

# Redis (Upstash REST)
UPSTASH_REDIS_REST_URL=https://your-project.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Supabase Storage (for screenshot uploads)
SUPABASE_URL=https://[project].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_BUCKET=fairgig-screenshots

# Anomaly service URL (Python FastAPI)
ANOMALY_SERVICE_URL=http://localhost:8000

# Logging
LOG_LEVEL=info
