// Auth Service — Prisma Schema
// Schemas owned: auth, audit

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  output          = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["auth", "audit"]
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  worker
  verifier
  advocate
  admin

  @@schema("auth")
}

enum Language {
  en
  ur

  @@schema("auth")
}

enum UserStatus {
  active
  frozen
  deleted

  @@schema("auth")
}

enum RequestStatus {
  pending
  approved
  rejected

  @@schema("auth")
}

// ─────────────────────────────────────────────────────────────────────────────
// auth.users
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique
  phone        String?
  passwordHash String     @map("password_hash")
  name         String
  role         Role       @default(worker)
  language     Language   @default(en)
  status       UserStatus @default(active)
  cityZoneId   String?    @map("city_zone_id") @db.Uuid
  categories   String[]

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  refreshTokens       RefreshToken[]
  roleRequests        RoleRequest[]
  passwordResetTokens PasswordResetToken[]

  @@index([role], name: "idx_users_role")
  @@index([cityZoneId], name: "idx_users_zone")
  @@map("users")
  @@schema("auth")
}

// ─────────────────────────────────────────────────────────────────────────────
// auth.refresh_tokens
// ─────────────────────────────────────────────────────────────────────────────

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @map("token_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz
  replacedBy String?   @map("replaced_by") @db.Uuid
  userAgent  String?   @map("user_agent")
  ip         String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "idx_refresh_tokens_user")
  @@index([tokenHash], name: "idx_refresh_tokens_hash")
  @@map("refresh_tokens")
  @@schema("auth")
}

// ─────────────────────────────────────────────────────────────────────────────
// auth.role_requests
// ─────────────────────────────────────────────────────────────────────────────

model RoleRequest {
  id            String        @id @default(uuid()) @db.Uuid
  userId        String        @map("user_id") @db.Uuid
  requestedRole Role          @map("requested_role")
  reason        String?
  status        RequestStatus @default(pending)
  decidedBy     String?       @map("decided_by") @db.Uuid
  decidedAt     DateTime?     @map("decided_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status], name: "idx_role_requests_status")
  @@map("role_requests")
  @@schema("auth")
}

// ─────────────────────────────────────────────────────────────────────────────
// auth.password_reset_tokens
// ─────────────────────────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash], name: "idx_pwd_reset_hash")
  @@map("password_reset_tokens")
  @@schema("auth")
}

// ─────────────────────────────────────────────────────────────────────────────
// audit.events  (append-only; shared across all services)
// ─────────────────────────────────────────────────────────────────────────────

model AuditEvent {
  id        String   @id @default(uuid()) @db.Uuid
  actorId   String?  @map("actor_id") @db.Uuid
  actorRole String?  @map("actor_role")
  action    String
  entity    String
  entityId  String   @map("entity_id")
  diff      Json     @default("{}")
  ip        String?
  ua        String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([entity, entityId], name: "idx_audit_entity")
  @@index([actorId], name: "idx_audit_actor")
  @@map("events")
  @@schema("audit")
}
