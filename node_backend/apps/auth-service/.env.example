# ── Auth Service Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in real values before running.
# NEVER commit the .env file to version control.

# Server
NODE_ENV=development
PORT=3001

# Database
# Supabase example: postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
# Render  example: postgresql://user:pass@host:5432/fairgig
# NOTE: If using Supabase, the 'auth' schema name conflicts with Supabase's reserved
#       auth system. Rename it to 'app_auth' in prisma/schema.prisma and init.sql.
DATABASE_URL=postgresql://postgres:password@localhost:5432/fairgig

# JWT — shared with ALL other services (they verify but don't sign)
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=change_me_to_a_64_char_random_hex_string

# Token lifetimes
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Cookies
COOKIE_SECRET=change_me_to_another_random_secret

# CORS — comma-separated list of allowed frontend origins
FRONTEND_ORIGINS=http://localhost:5173

# Email (Resend / Postmark)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@fairgig.app

# Password reset link base URL (no trailing slash)
RESET_TOKEN_BASE_URL=http://localhost:5173/reset-password

# Redis (optional — falls back to in-memory rate limiting if omitted)
# Upstash example: redis://default:[token]@[host].upstash.io:6379
REDIS_URL=

# Logging
LOG_LEVEL=info
