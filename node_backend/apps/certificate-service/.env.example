# ── Certificate Service Environment Variables ────────────────────────────────
# Copy this file to .env and fill in real values before running.
# NEVER commit the .env file to version control.

# Server
NODE_ENV=development
PORT=3003

# Database (same Postgres instance, reads earnings schema for verified shifts)
DATABASE_URL=postgresql://postgres:password@localhost:5432/fairgig

# JWT — must match the value in auth-service (this service only verifies)
JWT_SECRET=change_me_to_a_64_char_random_hex_string

# CORS
FRONTEND_ORIGINS=http://localhost:5173

# Supabase (for serving screenshot signed URLs on certificate)
SUPABASE_URL=https://[project].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Certificate sharing
# Base URL used to build public share links returned to workers
CERT_SHARE_BASE_URL=http://localhost:3003

# Default share link TTL in days (can be overridden per request)
CERT_SHARE_TTL_DAYS=14

# Logging
LOG_LEVEL=info
