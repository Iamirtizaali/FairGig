# ── Grievance Service Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in real values before running.
# NEVER commit the .env file to version control.

# Server
NODE_ENV=development
PORT=3004

# Database (same Postgres instance, grievance schema)
DATABASE_URL=postgresql://postgres:password@localhost:5432/fairgig

# JWT — must match the value in auth-service (this service only verifies)
JWT_SECRET=change_me_to_a_64_char_random_hex_string

# CORS
FRONTEND_ORIGINS=http://localhost:5173

# Redis (optional — used for caching grievance KPI counts)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info
