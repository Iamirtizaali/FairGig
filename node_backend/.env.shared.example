# Shared across all node services
# Use this same JWT secret in every service environment.
JWT_SECRET=replace_with_strong_shared_signing_key

# Neon pooled connection URL
DATABASE_URL=postgresql://neondb_owner:password@host/neondb?sslmode=require&channel_binding=require

# Upstash Redis (for BullMQ)
REDIS_URL=rediss://default:password@your-upstash-host:6379
